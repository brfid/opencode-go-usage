# Copy to .env and fill in. The .env file is git-ignored.

# Required: your opencode.ai `auth` cookie (see README § Get your session cookie).
OPENCODE_AUTH_COOKIE=Fe26.2**...

# Optional: pin the workspace id (otherwise auto-detected).
# OPENCODE_WORKSPACE_ID=wrk_...

# Optional: alert thresholds (percent) — warn to stderr when a window crosses.
# ALERT_ROLLING_PCT=90
# ALERT_WEEKLY_PCT=85
# ALERT_MONTHLY_PCT=95
