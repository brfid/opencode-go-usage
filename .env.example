# Copy to .env and fill in. The .env file is git-ignored.

# === OpenCode Go ===
# Required: your opencode.ai `auth` cookie (see README § Cookie acquisition).
OPENCODE_AUTH_COOKIE=your-auth-cookie-here

# Required: your workspace id, the wrk_... in your Go page URL.
OPENCODE_WORKSPACE_ID=wrk_...

# === ClinePass ===
# Required: your cline_session_id cookie from app.cline.bot.
CLINE_SESSION_ID=your-cline-session-id-here

# === Optional: alert thresholds for both scrapers (percent) ===
# Override with ALERT_<WINDOW>_PCT env vars.
# ALERT_ROLLING_PCT=90
# ALERT_WEEKLY_PCT=85
# ALERT_MONTHLY_PCT=95
# ALERT_FIVE_HOUR_PCT=90

# === Watchdog config (opencode_go_watchdog.py) ===
# TRIGGER_PCT=95
# SAFE_SHORT_PCT=80
# SAFE_MEDIUM_PCT=90
# SAFE_LONG_PCT=95
